{
  "manifest_version": 3,
  "name": "JobMatcher - AI 岗位匹配助手",
  "version": "1.0",
  "description": "一键采集招聘网站 JD，AI 智能匹配你的经历库",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.zhipin.com/*",
    "https://*.liepin.com/*",
    "https://*.51job.com/*",
    "https://*.zhaopin.com/*",
    "https://job-matcher-vui2.onrender.com/*"
  ],
  "action": {
    "default_title": "JobMatcher",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zhipin.com/*",
        "https://*.liepin.com/*",
        "https://*.51job.com/*",
        "https://*.zhaopin.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
